{
  "name": "klatchr",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": { "node": ">=20" },
  "pnpm": { "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"] },
  "lint-staged": {
    "*.{ts,tsx,cjs,js,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "scripts": {
    "test": "vitest run",
    "test:core": "vitest run packages/core",
    "test:cov": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "depcruise": "depcruise packages apps --config .dependency-cruiser.cjs",
    "jscpd": "jscpd .",
    "type-coverage": "pnpm -r exec type-coverage --at-least 99.9 --ignore-files '**/*.test.ts'",
    "knip": "knip",
    "gate": "bash scripts/gate.sh",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "licenses:check": "bash .hooks/check-licenses.sh",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "2.1.9",
    "dependency-cruiser": "16.10.4",
    "husky": "9.1.7",
    "jscpd": "4.2.5",
    "knip": "5.88.1",
    "lint-staged": "15.5.2",
    "type-coverage": "2.29.7",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
